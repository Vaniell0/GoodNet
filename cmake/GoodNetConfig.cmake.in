# GoodNetConfig.cmake.in — шаблон конфигурационного файла GoodNet SDK.
# Генерируется cmake из CMakeLists.txt при INSTALL_DEVELOPMENT=ON.
# Устанавливается в lib/cmake/GoodNet/GoodNetConfig.cmake.
#
# Используется плагинами:
#   find_package(GoodNet REQUIRED)       # загружает этот файл
#   include(${GOODNET_SDK_HELPER})       # загружает helper.cmake с add_plugin()
#   add_plugin(myplugin myplugin.cpp)    # создаёт SHARED таргет

include(CMakeFindDependencyMacro)

# ── Зависимости нужные при линковке с GoodNet::core ──────────────────────────
#
# spdlog и fmt: PUBLIC зависимости goodnet_core (используются в logger.hpp).
# Плагин не линкует их напрямую, но cmake требует их наличия для
# корректного разрешения INTERFACE_LINK_LIBRARIES таргета GoodNet::core.
#
# nlohmann_json: PRIVATE зависимость goodnet_core (только в config.cpp).
# НЕ перечислена здесь — плагинам не нужна.
# Символы json уже скомпилированы в libgoodnet_core.so.
#
# Boost: PRIVATE зависимость goodnet_core.
# Плагины с Boost добавляют его сами через find_package(Boost).

find_dependency(spdlog REQUIRED)
find_dependency(fmt    REQUIRED)

# ── Таргеты ───────────────────────────────────────────────────────────────────
include("${CMAKE_CURRENT_LIST_DIR}/GoodNetTargets.cmake")

# ── Пути для helper.cmake и PCH ───────────────────────────────────────────────
set(GOODNET_SDK_HELPER "${CMAKE_CURRENT_LIST_DIR}/helper.cmake")
set(GOODNET_PCH_CMAKE  "${CMAKE_CURRENT_LIST_DIR}/pch.cmake")
set(GOODNET_SDK_PATH   "@CMAKE_INSTALL_PREFIX@/include/goodnet/sdk")
set(GOODNET_INC_PATH   "@CMAKE_INSTALL_PREFIX@/include/goodnet")

include("${GOODNET_SDK_HELPER}")
